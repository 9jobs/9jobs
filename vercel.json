{
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/.next",
  "functions": {
    "api/index.js": {
      "includeFiles": "server/views/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron/import-social-posts",
      "schedule": "0 2 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/create-checkout-session",
      "destination": "/api/create-checkout-session.js"
    },
    {
      "source": "/api/newsletter",
      "destination": "/frontend/api/newsletter"
    },
    {
      "source": "/api/contact",
      "destination": "/frontend/api/contact"
    },
    {
      "source": "/api/:path((?!cron|admin|agreements|client-service-feedback|docusign|interview-feedback|contact|newsletter).*)",
      "destination": "/api/index.js"
    }
  ]
}
